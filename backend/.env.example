# Database
DATABASE_URL=postgresql://user:password@localhost:5432/travel_wallet

# Redis (QR sessions; optional - use in-memory fallback if not set)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# API port (frontend expects 3000 by default)
PORT=3000
# Bind address: 0.0.0.0 = reachable from LAN (mobile/other devices); localhost = same machine only
HOST=0.0.0.0

# CORS (comma-separated origins; include the port Vite uses, e.g. 5173 or 5174)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5179

# Base URL for uploaded file links (default http://localhost:3000)
# API_BASE_URL=http://localhost:3000

# Optional: web app (Vite) uses VITE_API_URL; mobile (Expo) uses EXPO_PUBLIC_API_URL (default http://localhost:3000)
