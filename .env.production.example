# Copy to .env on the server and fill in values. Do not commit .env.

# PostgreSQL (used by docker-compose for the db service and DATABASE_URL for backend)
POSTGRES_USER=travelwallet
POSTGRES_PASSWORD=change-me-secure-password
POSTGRES_DB=travel_wallet

# JWT (use a long random string in production)
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# API
PORT=3000
HOST=0.0.0.0

# Public URL of your API (for upload links and CORS). Use your domain or VPS IP for now.
# Examples: https://api.yourdomain.com  or  http://YOUR_VPS_IP:3000
API_BASE_URL=http://YOUR_VPS_IP:3000

# Allowed origins (comma-separated). Include your web app URL and any admin URL.
# Examples: https://app.yourdomain.com,https://yourdomain.com  or  http://YOUR_VPS_IP:3000
CORS_ORIGINS=http://localhost:5173,http://YOUR_VPS_IP:3000

# Optional: Redis for QR sessions (leave unset to use in-memory fallback)
# REDIS_URL=redis://redis:6379
