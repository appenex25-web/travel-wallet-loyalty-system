# Copy to .env on the server and fill in values. Do not commit .env.

# PostgreSQL (used by docker-compose for the db service and DATABASE_URL for backend)
POSTGRES_USER=travelwallet
POSTGRES_PASSWORD=change-me-secure-password
POSTGRES_DB=travel_wallet

# JWT (use a long random string in production)
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# API
PORT=3000
HOST=0.0.0.0

# Public URL of your API (for upload links). Also used as allowed CORS origin when set.
# Set to your live site, e.g. https://www.appenex.org (same host as the web app).
API_BASE_URL=http://YOUR_VPS_IP:3000

# Extra CORS origins (comma-separated). API_BASE_URL origin is allowed automatically.
# Add more if the web app is on a different domain, e.g. https://appenex.org
CORS_ORIGINS=http://localhost:5173

# Optional: Redis for QR sessions (leave unset to use in-memory fallback)
# REDIS_URL=redis://redis:6379
